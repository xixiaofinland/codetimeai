---
interface Props {
  slug: string
  title: string
  date: Date
  description: string
  guest?: string
  duration?: string
  isLegacy: boolean
  episodeNumber?: number
}

const { slug, title, date, description, guest, duration, isLegacy, episodeNumber } = Astro.props

const dateStr = date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})
---

{isLegacy ? (
  <!-- Legacy card: warm, faded, archive-feeling -->
  <article class="group border border-dashed border-stone-700/50 rounded p-5 hover:border-amber-800/70 transition-colors bg-stone-950/30">
    <a href={`/episodes/${slug}`} class="block">
      <div class="flex items-start justify-between gap-4 mb-2">
        <div class="flex items-center gap-2">
          {episodeNumber !== undefined && (
            <span class="font-mono text-xs text-amber-700/70">
              #{String(episodeNumber).padStart(3, '0')}
            </span>
          )}
        </div>
        {duration && (
          <span class="text-xs text-stone-600 font-mono shrink-0">{duration}</span>
        )}
      </div>
      <h2 class="font-mono text-sm font-medium leading-snug mb-1.5 text-amber-100/80 group-hover:text-amber-400 transition-colors">
        {title}
      </h2>
      <p class="text-xs text-stone-500 line-clamp-2 mb-3 leading-relaxed">{description}</p>
      <div class="flex items-center gap-3 text-xs text-stone-600 font-mono">
        <time datetime={date.toISOString()}>{dateStr}</time>
        {guest && <span>· {guest}</span>}
      </div>
    </a>
  </article>
) : (
  <!-- New card: sharp, modern, bright -->
  <article class="group border border-zinc-800 rounded-lg p-5 hover:border-zinc-600 transition-colors bg-zinc-900/40">
    <a href={`/episodes/${slug}`} class="block">
      <div class="flex items-start justify-between gap-4 mb-2">
        <div class="flex items-center gap-2">
          {episodeNumber !== undefined && (
            <span class="font-mono text-xs text-orange-500 font-bold">
              #{String(episodeNumber).padStart(3, '0')}
            </span>
          )}
        </div>
        {duration && (
          <span class="text-xs text-zinc-500 font-mono shrink-0">{duration}</span>
        )}
      </div>
      <h2 class="font-semibold leading-snug mb-1.5 group-hover:text-orange-400 transition-colors">
        {title}
      </h2>
      <p class="text-sm text-zinc-400 line-clamp-2 mb-3">{description}</p>
      <div class="flex items-center gap-3 text-xs text-zinc-500">
        <time datetime={date.toISOString()}>{dateStr}</time>
        {guest && <span>· 嘉宾：{guest}</span>}
      </div>
    </a>
  </article>
)}
