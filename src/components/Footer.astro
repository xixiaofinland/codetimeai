    <p>© {year} CodeTime AI</p>
    <div class="flex items-center gap-5">
      <a href="/feed.xml" class="hover:text-zinc-300 transition-colors">RSS</a>
      <a
        href="https://pinecast.com"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-zinc-300 transition-colors"
      >
        Pinecast
      </a>
    </div>
  </div>
</footer>
