---
import Base from '../../layouts/Base.astro'
import { getCollection, getEntry } from 'astro:content'

export async function getStaticPaths() {
  const episodes = await getCollection('episodes')
  return episodes.map((ep) => ({ params: { slug: ep.slug } }))
}

const { slug } = Astro.params
const episode = await getEntry('episodes', slug as string)

if (!episode) return Astro.redirect('/episodes')

const { Content } = await episode.render()
const { title, date, description, audioUrl, duration, guest, episodeNumber, isLegacy, tags } =
  episode.data
const playbackSpeeds = [
  { value: '1', label: '1×' },
  { value: '1.2', label: '1.2×' },
  { value: '1.5', label: '1.5×' },
  { value: '2', label: '2×' },
]
const playbackSkips = [
  { seconds: -15, label: '-15 秒' },
  { seconds: 15, label: '+15 秒' },
]

const dateStr = date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})
---

<Base title={title} description={description}>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <a
      href="/episodes"
      class="inline-flex items-center gap-1 text-sm text-zinc-500 hover:text-zinc-300 transition-colors mb-8"
    >
      ← 节目列表
    </a>

    <header class="mb-8">
      <div class="flex items-center gap-2 mb-3 flex-wrap">
        {episodeNumber !== undefined && (
          <span class="font-mono text-sm text-orange-500 font-bold">
            #{String(episodeNumber).padStart(3, '0')}
          </span>
        )}
        {isLegacy && (
          <span class="text-xs px-2 py-0.5 rounded bg-zinc-800 text-zinc-500">
            迁移自喜马拉雅
          </span>
        )}
        {tags.map((tag) => (
          <span class="text-xs px-2 py-0.5 rounded bg-zinc-800/60 text-zinc-400">{tag}</span>
        ))}
      </div>
      <h1 class="text-2xl font-bold leading-snug mb-3">{title}</h1>
      <div class="flex items-center gap-3 text-sm text-zinc-500 flex-wrap">
        <time datetime={date.toISOString()}>{dateStr}</time>
        {guest && <span>· 嘉宾：{guest}</span>}
        {duration && <span class="font-mono">· {duration}</span>}
      </div>
    </header>

    <!-- Audio player -->
    <div class="mb-8 rounded-lg border border-zinc-800 bg-zinc-900 p-4" data-audio-player>
      <audio controls preload="metadata" class="w-full rounded-lg" src={audioUrl} data-audio-element>
        您的浏览器不支持音频播放。
        <a href={audioUrl} class="text-orange-400 underline">直接下载</a>
      </audio>
      <div class="mt-3 flex flex-wrap justify-center gap-2">
        {playbackSkips.map(({ seconds, label }) => (
          <button
            type="button"
            class="rounded-full border border-zinc-700 bg-zinc-950 px-3 py-1 text-sm text-zinc-300 transition-colors hover:border-orange-500 hover:text-white"
            data-skip-button
            data-skip-seconds={seconds}
          >
            {label}
          </button>
        ))}
        {playbackSpeeds.map(({ value, label }, index) => (
          <button
            type="button"
            class:list={[
              'rounded-full border px-3 py-1 text-sm transition-colors',
              index === 0
                ? 'border-orange-500 bg-orange-500 text-white'
                : 'border-zinc-700 bg-zinc-950 text-zinc-300 hover:border-orange-500 hover:text-white',
            ]}
            data-speed-button
            data-speed={value}
            aria-pressed={index === 0 ? 'true' : 'false'}
          >
            {label}
          </button>
        ))}
      </div>
    </div>

    <p class="text-zinc-300 leading-relaxed mb-10">{description}</p>

    <!-- Show notes -->
    <div class="prose prose-invert prose-zinc max-w-none prose-a:text-orange-400 prose-headings:font-semibold">
      <Content />
    </div>
  </article>

  <script is:inline>
    const playbackSpeedStorageKey = 'playback-speed'

    document.querySelectorAll('[data-audio-player]').forEach((player) => {
      const audio = player.querySelector('[data-audio-element]')
      const speedButtons = [...player.querySelectorAll('[data-speed-button]')]
      const skipButtons = [...player.querySelectorAll('[data-skip-button]')]

      if (!(audio instanceof HTMLAudioElement) || speedButtons.length === 0) {
        return
      }

      const setActiveButton = (speed) => {
        speedButtons.forEach((button) => {
          const isActive = button.dataset.speed === speed

          button.classList.toggle('border-orange-500', isActive)
          button.classList.toggle('bg-orange-500', isActive)
          button.classList.toggle('text-white', isActive)
          button.classList.toggle('border-zinc-700', !isActive)
          button.classList.toggle('bg-zinc-950', !isActive)
          button.classList.toggle('text-zinc-300', !isActive)
          button.setAttribute('aria-pressed', String(isActive))
        })
      }

      const setPlaybackSpeed = (speed, persist = true) => {
        const parsedSpeed = Number.parseFloat(speed)

        if (!Number.isFinite(parsedSpeed)) {
          return
        }

        audio.playbackRate = parsedSpeed
        setActiveButton(speed)

        if (persist) {
          try {
            localStorage.setItem(playbackSpeedStorageKey, speed)
          } catch {}
        }
      }

      const skipPlayback = (offsetSeconds) => {
        const nextTime = Math.max(audio.currentTime + offsetSeconds, 0)

        audio.currentTime = Number.isFinite(audio.duration) ? Math.min(nextTime, audio.duration) : nextTime
      }

      let savedSpeed = null

      try {
        savedSpeed = localStorage.getItem(playbackSpeedStorageKey)
      } catch {}

      const initialSpeed = speedButtons.some((button) => button.dataset.speed === savedSpeed)
        ? savedSpeed
        : '1'

      setPlaybackSpeed(initialSpeed, false)

      speedButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const speed = button.dataset.speed

          if (speed) {
            setPlaybackSpeed(speed)
          }
        })
      })

      skipButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const seconds = Number.parseFloat(button.dataset.skipSeconds ?? '')

          if (Number.isFinite(seconds)) {
            skipPlayback(seconds)
          }
        })
      })
    })
  </script>
</Base>
