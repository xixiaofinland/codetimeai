---
import Base from '../../layouts/Base.astro'
import EpisodeCard from '../../components/EpisodeCard.astro'
import { getCollection } from 'astro:content'

const all = await getCollection('episodes')
const sorted = all.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())

const newEps = sorted.filter((ep) => !ep.data.isLegacy)
const legacyEps = sorted.filter((ep) => ep.data.isLegacy)
---

<Base title="节目列表">
  <div class="max-w-3xl mx-auto px-4 py-10">

    <!-- Tab navigation -->
    <div class="flex items-center gap-0 mb-10 border-b border-zinc-800">
      {newEps.length > 0 && (
        <a
          href="#new"
          class="px-5 py-2.5 text-sm font-medium text-orange-400 border-b-2 border-orange-500 -mb-px transition-colors"
        >
          新节目
          <span class="ml-1.5 text-xs text-orange-500/70 font-mono">({newEps.length})</span>
        </a>
      )}
      {legacyEps.length > 0 && (
        <a
          href="#archive"
          class="px-5 py-2.5 text-sm font-medium text-stone-500 hover:text-stone-300 border-b-2 border-transparent -mb-px transition-colors font-mono"
        >
          历史档案
          <span class="ml-1.5 text-xs opacity-60">({legacyEps.length})</span>
        </a>
      )}
    </div>

    <!-- New episodes -->
    {newEps.length > 0 && (
      <section id="new" class="mb-16 scroll-mt-20">
        <div class="flex items-baseline gap-3 mb-6">
          <h2 class="text-lg font-bold">新节目</h2>
          <span class="font-mono text-xs text-zinc-600">2025 →</span>
        </div>
        <div class="flex flex-col gap-3">
          {newEps.map((ep) => (
            <EpisodeCard
              slug={ep.slug}
              title={ep.data.title}
              date={ep.data.date}
              description={ep.data.description}
              guest={ep.data.guest}
              duration={ep.data.duration}
              isLegacy={ep.data.isLegacy}
              episodeNumber={ep.data.episodeNumber}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Legacy archive -->
    {legacyEps.length > 0 && (
      <section id="archive" class="scroll-mt-20">
        <!-- Archive header with old-school feel -->
        <div class="mb-6 pb-4 border-b border-dashed border-stone-800">
          <div class="font-mono text-xs text-stone-600 mb-1">── archive ──────────────────</div>
          <div class="flex items-baseline gap-3">
            <h2 class="font-mono text-base text-amber-700/80">历史档案</h2>
            <span class="font-mono text-xs text-stone-600">2016 – 2019</span>
          </div>
          <p class="text-xs text-stone-600 font-mono mt-1">迁移自喜马拉雅 · {legacyEps.length} 期</p>
        </div>
        <div class="flex flex-col gap-2">
          {legacyEps.map((ep) => (
            <EpisodeCard
              slug={ep.slug}
              title={ep.data.title}
              date={ep.data.date}
              description={ep.data.description}
              guest={ep.data.guest}
              duration={ep.data.duration}
              isLegacy={ep.data.isLegacy}
              episodeNumber={ep.data.episodeNumber}
            />
          ))}
        </div>
      </section>
    )}

  </div>
</Base>
