---
import Base from '../layouts/Base.astro'
import EpisodeCard from '../components/EpisodeCard.astro'
import { getCollection } from 'astro:content'

const all = await getCollection('episodes')
const sorted = all.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
const newEps = sorted.filter((ep) => !ep.data.isLegacy)
const recentNew = newEps.slice(0, 5)
const legacyCount = sorted.filter((ep) => ep.data.isLegacy).length
---

<Base title="首页">
  <!-- Hero -->
  <section class="max-w-3xl mx-auto px-4 pt-20 pb-16">
    <p class="font-mono text-orange-500 text-xs mb-4 tracking-wide">
      $ podcast --lang zh-CN --topic programming,ai
    </p>
    <h1 class="flex items-center gap-3 text-4xl font-bold tracking-tight mb-4">
      <img src="/favicon.png" alt="" class="w-10 h-10 rounded-lg" />
      代码时间
    </h1>
    <p class="text-lg text-zinc-400 leading-relaxed max-w-lg">
      聊编程，聊 AI，聊程序员的那些事。<br />
      不定期更新，有聊有料。
    </p>
    <div class="flex items-center gap-3 mt-8">
      <a
        href="/episodes"
        class="px-4 py-2 bg-orange-500 hover:bg-orange-400 text-zinc-950 font-semibold rounded text-sm transition-colors"
      >
        浏览全部节目
      </a>
      <a
        href="/feed.xml"
        class="px-4 py-2 border border-zinc-700 hover:border-zinc-500 text-zinc-300 rounded text-sm transition-colors"
      >
        RSS 订阅
      </a>
    </div>
  </section>

  <!-- New episodes -->
  {recentNew.length > 0 && (
    <section class="max-w-3xl mx-auto px-4 pb-16">
      <h2 class="font-mono text-xs text-zinc-500 uppercase tracking-widest mb-5">最新节目</h2>
      <div class="flex flex-col gap-3">
        {recentNew.map((ep) => (
          <EpisodeCard
            slug={ep.slug}
            title={ep.data.title}
            date={ep.data.date}
            description={ep.data.description}
            guest={ep.data.guest}
            duration={ep.data.duration}
            isLegacy={ep.data.isLegacy}
            episodeNumber={ep.data.episodeNumber}
          />
        ))}
      </div>
      {newEps.length > 5 && (
        <div class="mt-6 text-center">
          <a href="/episodes" class="text-sm text-zinc-400 hover:text-zinc-100 transition-colors">
            查看全部 {newEps.length} 期 →
          </a>
        </div>
      )}
    </section>
  )}

  <!-- Archive teaser -->
  {legacyCount > 0 && (
    <section class="max-w-3xl mx-auto px-4 pb-20">
      <a
        href="/episodes#archive"
        class="group block rounded border border-dashed border-stone-800 bg-stone-950/20 p-6 transition-colors hover:border-stone-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-500/70 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-950"
      >
        <div class="font-mono text-xs text-stone-600 mb-2">── archive ──</div>
        <p class="text-sm text-stone-500 font-mono">
          节目从 2016 年一路播到 2019 年，共 {legacyCount} 期历史节目已归档。
        </p>
        <div class="mt-3 text-xs font-mono text-amber-700/80 transition-colors group-hover:text-amber-500">
          → 浏览历史档案
        </div>
      </a>
    </section>
  )}
</Base>
